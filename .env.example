# Optional — when set, the site reads products from this published Google Sheet (CSV).
# See SHEET_SETUP.md for instructions. Leave unset to use the built-in placeholder catalogue.
VITE_PRODUCTS_SHEET_URL=

# Stripe Checkout (required for real payments). Get both keys from:
# https://dashboard.stripe.com/test/apikeys  (use test-mode keys during development)
#
# VITE_STRIPE_PUBLISHABLE_KEY is bundled into the client; safe to expose.
# STRIPE_SECRET_KEY is used server-side only (inside /api/checkout); keep it secret.
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Optional — override the origin used for Stripe success/cancel URLs.
# If unset, the API uses the request's host. Useful for local dev.
# SITE_ORIGIN=http://localhost:3000
